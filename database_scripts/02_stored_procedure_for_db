CREATE PROCEDURE sp_TransformEducationData
AS
BEGIN
    INSERT INTO DimTerritory (Country, City, LivingCostIndex)
    SELECT DISTINCT 
        Country, 
        City, 
        Living_Cost_Index
    FROM stg_education_costs
    WHERE NOT EXISTS (
        SELECT 1 FROM DimTerritory dt 
        WHERE dt.Country = stg_education_costs.Country AND dt.City = stg_education_costs.City
    );

    INSERT INTO DimMajor (UniversityName, Program, Degree, Duration_Years)
    SELECT DISTINCT 
        University, 
        Program, 
        Level, 
        Duration_Years
    FROM stg_education_costs
    WHERE NOT EXISTS (
        SELECT 1 FROM DimMajor dm 
        WHERE dm.UniversityName = stg_education_costs.University AND dm.Program = stg_education_costs.Program
    );

    INSERT INTO DimCurrency (Money)
    SELECT DISTINCT 
        Exchange_Rate
    FROM stg_education_costs
    WHERE NOT EXISTS (
        SELECT 1 FROM DimCurrency dc 
        WHERE dc.Money = stg_education_costs.Exchange_Rate
    );

    INSERT INTO fact_education_cost (
        Country, City, University, Program, Level, Duration_Years,
        Tuition_USD, location, Visa_Fee_USD, Rent_USD, Insurance_USD, Exchange_Rate
    )
    SELECT 
        stg.Country, 
        stg.City, 
        dm.UniversitiesID, 
        stg.Program, 
        stg.Level, 
        stg.Duration_Years,
        stg.Tuition_USD, 
        dt.TeritoryID, 
        stg.Visa_Fee_USD, 
        stg.Rent_USD, 
        stg.Insurance_USD, 
        dc.CurrencyID
    FROM stg_education_costs stg
    LEFT JOIN DimTerritory dt 
        ON stg.Country = dt.Country AND stg.City = dt.City
    LEFT JOIN DimMajor dm 
        ON stg.University = dm.UniversityName AND stg.Program = stg.Program
    LEFT JOIN DimCurrency dc 
        ON stg.Exchange_Rate = dc.Money;

    TRUNCATE TABLE stg_education_costs;
END;