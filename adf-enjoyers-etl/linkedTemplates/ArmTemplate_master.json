{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-enjoyers-etl"
		},
		"LS_Blob_EnjoyersStorage_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_Blob_EnjoyersStorage'"
		},
		"LS_SQL_EnjoyersDatabase_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_SQL_EnjoyersDatabase'"
		},
		"LS_Http_AdzunaAPI_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "@{linkedService().ApiUrl}"
		},
		"LS_Rest_AdzunaAPI_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://api.adzuna.com/v1/api/jobs/"
		},
		"LS_SQL_EnjoyersDatabase_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "enjoyers-database-server.database.windows.net"
		},
		"LS_SQL_EnjoyersDatabase_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "Enjoyers_database"
		},
		"LS_SQL_EnjoyersDatabase_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "enjoyer"
		},
		"TRG_Weekly_Adzuna_Ingestion_properties_PL_Ingest_Adzuna_parameters_AdzunaAppId": {
			"type": "string",
			"defaultValue": "b2486541"
		},
		"TRG_Weekly_Adzuna_Ingestion_properties_PL_Ingest_Adzuna_parameters_AdzunaAppKey": {
			"type": "string",
			"defaultValue": "d63e05cde4a5e6f64ad24471d2461a4f"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-enjoyers-etl_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_Blob_EnjoyersStorage_connectionString": {
						"value": "[parameters('LS_Blob_EnjoyersStorage_connectionString')]"
					},
					"LS_SQL_EnjoyersDatabase_password": {
						"value": "[parameters('LS_SQL_EnjoyersDatabase_password')]"
					},
					"LS_Http_AdzunaAPI_properties_typeProperties_url": {
						"value": "[parameters('LS_Http_AdzunaAPI_properties_typeProperties_url')]"
					},
					"LS_Rest_AdzunaAPI_properties_typeProperties_url": {
						"value": "[parameters('LS_Rest_AdzunaAPI_properties_typeProperties_url')]"
					},
					"LS_SQL_EnjoyersDatabase_properties_typeProperties_server": {
						"value": "[parameters('LS_SQL_EnjoyersDatabase_properties_typeProperties_server')]"
					},
					"LS_SQL_EnjoyersDatabase_properties_typeProperties_database": {
						"value": "[parameters('LS_SQL_EnjoyersDatabase_properties_typeProperties_database')]"
					},
					"LS_SQL_EnjoyersDatabase_properties_typeProperties_userName": {
						"value": "[parameters('LS_SQL_EnjoyersDatabase_properties_typeProperties_userName')]"
					},
					"TRG_Weekly_Adzuna_Ingestion_properties_PL_Ingest_Adzuna_parameters_AdzunaAppId": {
						"value": "[parameters('TRG_Weekly_Adzuna_Ingestion_properties_PL_Ingest_Adzuna_parameters_AdzunaAppId')]"
					},
					"TRG_Weekly_Adzuna_Ingestion_properties_PL_Ingest_Adzuna_parameters_AdzunaAppKey": {
						"value": "[parameters('TRG_Weekly_Adzuna_Ingestion_properties_PL_Ingest_Adzuna_parameters_AdzunaAppKey')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}