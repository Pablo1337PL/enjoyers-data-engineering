{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-enjoyers-etl"
		},
		"LS_Blob_EnjoyersStorage_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_Blob_EnjoyersStorage'"
		},
		"LS_SQL_EnjoyersDatabase_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_SQL_EnjoyersDatabase'"
		},
		"LS_SQL_EnjoyersDatabase_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "enjoyers-database-server.database.windows.net"
		},
		"LS_SQL_EnjoyersDatabase_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "Enjoyers_database"
		},
		"LS_SQL_EnjoyersDatabase_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "enjoyer"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/LS_Blob_EnjoyersStorage')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureBlobStorage",
				"typeProperties": {
					"connectionString": "[parameters('LS_Blob_EnjoyersStorage_connectionString')]"
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/LS_SQL_EnjoyersDatabase')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureSqlDatabase",
				"typeProperties": {
					"server": "[parameters('LS_SQL_EnjoyersDatabase_properties_typeProperties_server')]",
					"database": "[parameters('LS_SQL_EnjoyersDatabase_properties_typeProperties_database')]",
					"encrypt": "mandatory",
					"trustServerCertificate": false,
					"authenticationType": "SQL",
					"userName": "[parameters('LS_SQL_EnjoyersDatabase_properties_typeProperties_userName')]",
					"password": {
						"type": "SecureString",
						"value": "[parameters('LS_SQL_EnjoyersDatabase_password')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}